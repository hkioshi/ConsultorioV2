<UserControl x:Class="ConsultorioWPF.Views.PacientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F9FB">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="16"/>
            <!-- Espaço -->
            <RowDefinition Height="Auto"/>
            <!-- Stats cards -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <!-- Search + Filtros -->
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <!-- Tabela -->
        </Grid.RowDefinitions>

        <!-- ══════════ HEADER ══════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"  VerticalAlignment="Center" >
                <TextBlock Text="Pacientes"
                        Foreground="{StaticResource TextPrimary}"
                        FontSize="20"
                        FontWeight="SemiBold"
                        
                        FontFamily="Segoe UI"/>

                <TextBlock Text="Gerencie o cadastro e histórico dos seus pacientes"
                        Foreground="{StaticResource TextMuted}"
                        FontSize="12"
                        FontFamily="Segoe UI"
                        Margin="0,3,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                x:Name="BtnNovoPaciente"
                VerticalAlignment="Center"
                Style="{StaticResource btnAddPaciente}" Click="BtnNovoPaciente_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+"
                            FontSize="16"
                            FontWeight="Bold"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"/>
                    <TextBlock Text="Novo Paciente"
                            VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search com ícone de lupa -->
            <Grid Grid.Column="0">

                <TextBox x:Name="TxtBusca"
            Style="{StaticResource txtCaixaDeBusca}"
            TextChanged="TxtBusca_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="Border" BasedOn="{x:Null}"/>
                    </TextBox.Resources>
                </TextBox>
                <!-- Placeholder -->
                <TextBlock IsHitTestVisible="False"
            Text="Buscar por nome, CPF ou telefone..."
            Foreground="#2E5566"
            FontSize="13"
            FontFamily="Segoe UI"
            VerticalAlignment="Center"
            Margin="50,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtBusca}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <!-- Ícone lupa -->
                <Path Data="M10 2C5.6 2 2 5.6 2 10C2 14.4 5.6 18 10 18C11.8 18 13.4 17.4 14.7 16.4L18.3 20L20 18.3L16.4 14.7C17.4 13.4 18 11.8 18 10C18 5.6 14.4 2 10 2ZM10 4C13.3 4 16 6.7 16 10C16 13.3 13.3 16 10 16C6.7 16 4 13.3 4 10C4 6.7 6.7 4 10 4Z"
        Fill="{StaticResource TextPrimary}"
        Width="16" Height="16"
        Stretch="Uniform"
        HorizontalAlignment="Left"
        VerticalAlignment="Center"
        Margin="20,0,0,0"
        IsHitTestVisible="False"/>
            </Grid>

            <!-- Filter chips -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton x:Name="rdbNome" Content="Nome"   Style="{StaticResource rdbFiltro}" IsChecked="True" Margin="0,0,6,0"/>
                <RadioButton x:Name="rdbId" Content="ID"  Style="{StaticResource rdbFiltro}" Margin="0,0,6,0"/>
                <RadioButton x:Name="rdbCPF" Content="CPF" Style="{StaticResource rdbFiltro}" Margin="0,0,6,0"/>
            </StackPanel>
        </Grid>

        <!-- ══════════ TABELA ══════════ -->
        <Border Grid.Row="6"
            
            Style="{StaticResource Table}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border Grid.Row="0"
                    Style="{StaticResource PacientesHeader}">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <!-- ID -->
                            <ColumnDefinition Width="3*"/>
                            <!-- Paciente -->
                            <ColumnDefinition Width="2*"/>
                            <!-- Telefone -->
                            <ColumnDefinition Width="2*"/>
                            <!-- Ações -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="ID" Style="{StaticResource ColHeader}" />
                        <TextBlock Grid.Column="1" Text="PACIENTE" Style="{StaticResource ColHeader}" />
                        <TextBlock Grid.Column="2" Text="TELEFONE" Style="{StaticResource ColHeader}" />
                        <TextBlock Grid.Column="3" Text="AÇÕES" Style="{StaticResource ColHeader}" />
                    </Grid>
                </Border>

                <!-- LISTA -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Pacientes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource TableRow}">
                                    <Grid Height="53">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <!-- ID -->
                                            <ColumnDefinition Width="3*"/>
                                            <!-- Paciente -->
                                            <ColumnDefinition Width="2*"/>
                                            <!-- Telefone -->
                                            <ColumnDefinition Width="2*"/>
                                            <!-- Ações -->
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                           Text="{Binding Id}"
                                           Style="{StaticResource Cell}"/>

                                        <TextBlock Grid.Column="1"
                                           Text="{Binding Nome}"
                                           Style="{StaticResource Cell}"/>

                                        <TextBlock Grid.Column="2"
                                           Text="{Binding Telefone}"
                                           Style="{StaticResource Cell}"/>

                                      

                                        <!-- AÇÕES -->
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="✏" ToolTip="Editar" Style="{StaticResource BtnAction}"/>
                                            <Button Content="👤" ToolTip="Perfil Completo" Style="{StaticResource BtnAction}"/>
                                            <Button Content="📄" ToolTip="Prontuario"  Style="{StaticResource BtnAction}"/>

                                        </StackPanel>
                                    
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
