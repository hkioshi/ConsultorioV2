<Window x:Class="ConsultorioWPF.Views.NovoPacienteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Novo Paciente"
        Width="780" Height="700"
        MinWidth="680" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBg}"
        FontFamily="Segoe UI"
        ResizeMode="CanResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Título / header -->
            <RowDefinition Height="Auto"/>  <!-- Tabs de seção -->
            <RowDefinition Height="*"/>     <!-- Conteúdo -->
            <RowDefinition Height="Auto"/>  <!-- Footer / botões -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,0,0,1"
                Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Cadastro de Paciente"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Preencha os dados abaixo para adicionar um novo paciente"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="11"
                               Margin="0,3,0,0"/>
                </StackPanel>
                <!-- Botão fechar X -->
                <Button Grid.Column="1"
                        Content="✕"
                        Foreground="{StaticResource TextPrimary}"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="16"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="BtnFechar_Click"/>
            </Grid>
        </Border>

        <!-- ══ TABS ══ -->
        <Border Grid.Row="1"
                Background="{StaticResource AccentBlue}"
                BorderBrush="{StaticResource AccentSoft}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <RadioButton Content="Dados Pessoais" Style="{StaticResource TabBtn}" IsChecked="True"
                             Checked="Tab_Checked" Tag="TabPessoal"/>
                <RadioButton Content="Endereço e Contato" Style="{StaticResource TabBtn}"
                             Checked="Tab_Checked" Tag="TabContato"/>
                <RadioButton Content="Informações Extras" Style="{StaticResource TabBtn}"
                             Checked="Tab_Checked" Tag="TabExtra"/>
            </StackPanel>
        </Border>

        <!-- ══ CONTEÚDO DAS TABS ══ -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="28,24,28,8">
            <StackPanel>

                <!-- ════ TAB 1: DADOS PESSOAIS ════ -->
                <StackPanel x:Name="TabPessoal" Visibility="Visible">

                    <TextBlock Style="{StaticResource SectionTitle}" Text="IDENTIFICAÇÃO"/>

                    <!-- Nome -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Nome completo *"/>
                        <TextBox x:Name="TxtNome" Style="{StaticResource FormInput}"/>
                    </StackPanel>

                    <!-- CPF / RG -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="CPF *"/>
                            <TextBox x:Name="TxtCpf" Style="{StaticResource FormInput}"
                                     MaxLength="14" TextChanged="TxtCpf_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="RG"/>
                            <TextBox x:Name="TxtRg" Style="{StaticResource FormInput}" MaxLength="15"/>
                        </StackPanel>
                    </Grid>

                    <!-- Data Nasc / Gênero / Estado Civil -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Data de nascimento *"/>
                            <DatePicker x:Name="DtNascimento"
                                        Style="{StaticResource FormDate}"
                                        Language="pt-BR"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Gênero"/>
                            <ComboBox x:Name="CmbGenero" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="Feminino"/>
                                <ComboBoxItem Content="Masculino"/>
                                <ComboBoxItem Content="Não binário"/>
                                <ComboBoxItem Content="Prefiro não informar"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Estado civil"/>
                            <ComboBox x:Name="CmbEstadoCivil" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="Solteiro(a)"/>
                                <ComboBoxItem Content="Casado(a)"/>
                                <ComboBoxItem Content="Divorciado(a)"/>
                                <ComboBoxItem Content="Viúvo(a)"/>
                                <ComboBoxItem Content="União estável"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Responsável / Recomendado por -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Pessoa responsável"/>
                            <ComboBox x:Name="CmbResponsavel" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="— Selecione —"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Recomendado por"/>
                            <ComboBox x:Name="CmbRecomendadoPor" Style="{StaticResource FormCombo}" SelectionChanged="CmbRecomendadoPor_SelectionChanged">
                                <ComboBoxItem Content="— Selecione —"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                </StackPanel>

                <!-- ════ TAB 2: ENDEREÇO E CONTATO ════ -->
                <StackPanel x:Name="TabContato" Visibility="Collapsed">

                    <TextBlock Style="{StaticResource SectionTitle}" Text="ENDEREÇO"/>

                    <!-- CEP -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="CEP"/>
                            <Grid>
                                <TextBox x:Name="TxtCep" Style="{StaticResource FormInput}"
                                         MaxLength="9" TextChanged="TxtCep_TextChanged"/>
                                <Button x:Name="BtnBuscarCep"
                                        Content="Buscar"
                                        Foreground="#7ECFEE"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        FontFamily="Segoe UI"
                                        Cursor="Hand"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0"
                                        Click="BtnBuscarCep_Click"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Logradouro"/>
                            <TextBox x:Name="TxtLogradouro" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Número / Complemento -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Número"/>
                            <TextBox x:Name="TxtNumero" Style="{StaticResource FormInput}" MaxLength="10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Complemento"/>
                            <TextBox x:Name="TxtComplemento" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Bairro / Cidade / Estado -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Bairro"/>
                            <TextBox x:Name="TxtBairro" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Cidade"/>
                            <TextBox x:Name="TxtCidade" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="UF"/>
                            <ComboBox x:Name="CmbEstado" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="SP"/>
                                <ComboBoxItem Content="RJ"/>
                                <ComboBoxItem Content="MG"/>
                                <ComboBoxItem Content="RS"/>
                                <ComboBoxItem Content="PR"/>
                                <ComboBoxItem Content="SC"/>
                                <ComboBoxItem Content="BA"/>
                                <ComboBoxItem Content="GO"/>
                                <ComboBoxItem Content="DF"/>
                                <ComboBoxItem Content="PE"/>
                                <ComboBoxItem Content="CE"/>
                                <ComboBoxItem Content="AM"/>
                                <ComboBoxItem Content="PA"/>
                                <ComboBoxItem Content="MT"/>
                                <ComboBoxItem Content="MS"/>
                                <ComboBoxItem Content="ES"/>
                                <ComboBoxItem Content="RN"/>
                                <ComboBoxItem Content="PB"/>
                                <ComboBoxItem Content="AL"/>
                                <ComboBoxItem Content="PI"/>
                                <ComboBoxItem Content="SE"/>
                                <ComboBoxItem Content="MA"/>
                                <ComboBoxItem Content="TO"/>
                                <ComboBoxItem Content="RO"/>
                                <ComboBoxItem Content="AC"/>
                                <ComboBoxItem Content="AP"/>
                                <ComboBoxItem Content="RR"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Divisor -->
                    <Border Background="#1E3D52" Height="1" Margin="0,0,0,20"/>

                    <TextBlock Style="{StaticResource SectionTitle}" Text="CONTATO"/>

                    <!-- Telefone / Email -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Telefone / WhatsApp *"/>
                            <TextBox x:Name="TxtTelefone" Style="{StaticResource FormInput}"
                                     MaxLength="15" TextChanged="TxtTelefone_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="E-mail"/>
                            <TextBox x:Name="TxtEmail" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>

                <!-- ════ TAB 3: INFORMAÇÕES EXTRAS ════ -->
                <StackPanel x:Name="TabExtra" Visibility="Collapsed">

                    <TextBlock Style="{StaticResource SectionTitle}" Text="FAMÍLIA"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Nome do pai"/>
                            <TextBox x:Name="TxtNomePai" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Nome da mãe"/>
                            <TextBox x:Name="TxtNomeMae" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Nome do cônjuge"/>
                            <TextBox x:Name="TxtNomeConjuge" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Profissão"/>
                            <TextBox x:Name="TxtProfissao" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#1E3D52" Height="1" Margin="0,0,0,20"/>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="CONVÊNIO"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Convênio"/>
                            <TextBox x:Name="TxtConvenio" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Número do convênio"/>
                            <TextBox x:Name="TxtNumeroConvenio" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#1E3D52" Height="1" Margin="0,0,0,20"/>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="PREFERÊNCIAS"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Como nos conheceu"/>
                            <ComboBox x:Name="CmbConheceuPor" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="Indicação de paciente"/>
                                <ComboBoxItem Content="Redes sociais"/>
                                <ComboBoxItem Content="Google"/>
                                <ComboBoxItem Content="Plano de saúde"/>
                                <ComboBoxItem Content="Outro"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Preferência de horário"/>
                            <ComboBox x:Name="CmbPreferenciaHorario" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="Manhã"/>
                                <ComboBoxItem Content="Tarde"/>
                                <ComboBoxItem Content="Qualquer horário"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Observações"/>
                        <TextBox x:Name="TxtObservacoes" Style="{StaticResource FormTextArea}"/>
                    </StackPanel>

                    <CheckBox x:Name="ChkReceberLembretes"
                              Style="{StaticResource ToggleCheck}"
                              Content="Quero receber lembretes de consultas"
                              IsChecked="True"
                              Margin="0,4,0,0"/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="3"
                Background="{StaticResource PageBg}"
                BorderBrush="{StaticResource CardBorder}"
                BorderThickness="0,1,0,0"
                Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Indicador de campos obrigatórios -->
                <TextBlock Grid.Column="0"
                           Text="* Campos obrigatórios"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cancelar"
                            Style="{StaticResource BtnPrimary}"
                            Margin="0,0,10,0"
                            Click="BtnFechar_Click"/>
                    <Button Content="Salvar Paciente"
                            Style="{StaticResource BtnPrimary}"
                            Click="BtnSalvar_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
