<UserControl x:Class="ConsultorioWPF.Views.PacientePerfilView"
                          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ConsultorioWPF"
             mc:Ignorable="d" d:DesignWidth="800"
             Background="{StaticResource PageBg}" Height="569"
             >


    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="13"/>
            <!-- Espaço -->
            <RowDefinition Height="Auto"/>
            <!-- Stats cards -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- ══════════════ BRAND ══════════════ -->
        <Border Grid.Row="0"
        BorderBrush="{StaticResource CardBorder}"
        BorderThickness="0,0,0,1"
        Padding="28,20" Margin="0,0,0,16" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Cadastro de Paciente"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="16"
                       FontWeight="SemiBold"/>
                    <TextBlock Text="Preencha os dados abaixo para adicionar um novo paciente"
                       Foreground="{StaticResource TextPrimary}"
                       FontSize="11"
                       Margin="0,3,0,0"/>
                </StackPanel>
                <!-- Botão fechar X -->
                <Button Grid.Column="1"
                Content="✕"
                Foreground="{StaticResource TextPrimary}"
                Background="Transparent"
                BorderThickness="0"
                FontSize="16"
                Cursor="Hand"
                VerticalAlignment="Center"
                Click="BtnFechar_Click"/>
            </Grid>
        </Border>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Style="{StaticResource stkInfos}" >
                <!-- Dados básicos -->
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Id: " FontWeight="Bold"/><Run Text="{Binding Id}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Nome: " FontWeight="Bold"/><Run Text="{Binding Nome}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="CPF: " FontWeight="Bold"/><Run Text="{Binding Cpf}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="RG: " FontWeight="Bold"/><Run Text="{Binding Rg}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Data de Nascimento: " FontWeight="Bold"/><Run Text="{Binding DataNascimento}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Gênero: " FontWeight="Bold"/><Run Text="{Binding Genero}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Estado Civil: " FontWeight="Bold"/><Run Text="{Binding EstadoCivil}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Pessoa Responsável: " FontWeight="Bold"/><Run Text="{Binding PessoaResponsavelId}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Recomendado Por: " FontWeight="Bold"/><Run Text="{Binding RecomendadoPorId}"/></TextBlock>

                <!-- Contato -->
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="CEP: " FontWeight="Bold"/><Run Text="{Binding Cep}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Logradouro: " FontWeight="Bold"/><Run Text="{Binding Logradouro}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Número: " FontWeight="Bold"/><Run Text="{Binding Numero}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Complemento: " FontWeight="Bold"/><Run Text="{Binding Complemento}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Bairro: " FontWeight="Bold"/><Run Text="{Binding Bairro}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Cidade: " FontWeight="Bold"/><Run Text="{Binding Cidade}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Estado: " FontWeight="Bold"/><Run Text="{Binding Estado}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Telefone: " FontWeight="Bold"/><Run Text="{Binding Telefone}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Email: " FontWeight="Bold"/><Run Text="{Binding Email}"/></TextBlock>


            </StackPanel>
            <StackPanel Grid.Column="1" Style="{StaticResource stkInfos}">
                <!-- Extra -->
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Nome do Pai: " FontWeight="Bold"/><Run Text="{Binding NomePai}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Nome da Mãe: " FontWeight="Bold"/><Run Text="{Binding NomeMae}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Nome do Cônjuge: " FontWeight="Bold"/><Run Text="{Binding NomeConjuge}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Profissão: " FontWeight="Bold"/><Run Text="{Binding Profissao}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Conheceu Por: " FontWeight="Bold"/><Run Text="{Binding ConheceuPor}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Observações: " FontWeight="Bold"/><Run Text="{Binding Observacoes}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Convênio: " FontWeight="Bold"/><Run Text="{Binding Convenio}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Número do Convênio: " FontWeight="Bold"/><Run Text="{Binding NumeroConvenio}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Preferência de Horário: " FontWeight="Bold"/><Run Text="{Binding PreferenciaHorario}"/></TextBlock>
                <TextBlock Style="{StaticResource txtInfoPaciente}"><Run Text="Receber Lembretes: " FontWeight="Bold"/><Run Text="{Binding QueroReceberLembretes}"/></TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
