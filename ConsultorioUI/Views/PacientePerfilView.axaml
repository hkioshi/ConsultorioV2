<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ConsultorioUI.Views.PacientePerfilView"
             Background="{DynamicResource PageBg}">
    
    
<Grid RowDefinitions="Auto,*">

    <!-- ═══════════ HEADER ═══════════ -->
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="0,0,0,1"
            Padding="28,20">
        <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Cadastro de Paciente"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="16"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Preencha os dados abaixo para adicionar um novo paciente"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="11"
                           Margin="0,3,0,0"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Salvar Alteração"
                    Click="BtnSalvar_Click"
                    Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="0"
                    FontSize="16"
                    Cursor="Hand"
                    VerticalAlignment="Center"/>
        </Grid>
    </Border>

    <!-- ═══════════ CONTEÚDO (formulário) ═══════════ -->
    <ScrollViewer Grid.Row="1">
        <WrapPanel Orientation="Horizontal" Margin="20">

            <!-- ═══════════ DADOS PESSOAIS ═══════════ -->
            <Border Background="{DynamicResource CardBg}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,16,16"
                    Width="380">
                <StackPanel Spacing="12">
                    <TextBlock Text="Dados Pessoais" Classes="SectionTitle"/>

                 <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" 
                      RowSpacing="10" ColumnSpacing="10">

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Text="Nome completo" Classes="FieldLabel"/>
                        <TextBox x:Name="TxtNome" Classes="FormInput"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0">
                        <TextBlock Text="CPF" Classes="FieldLabel"/>
                        <TextBox x:Name="TxtCpf" Classes="FormInput"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1">
                        <TextBlock Text="RG" Classes="FieldLabel"/>
                        <TextBox x:Name="TxtRg" Classes="FormInput"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="Data de nascimento" Classes="FieldLabel"/>
                        <DatePicker x:Name="DtNascimento" Classes="FormDate"/>
                    </StackPanel>

                    <!-- Gênero agora sozinho, uma linha abaixo -->
                    <StackPanel Grid.Row="3" Grid.Column="0" >
                        <TextBlock Text="Gênero" Classes="FieldLabel"/>
                        <ComboBox x:Name="CmbGenero" Classes="FormCombo" HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Masculino"/>
                            <ComboBoxItem Content="Feminino"/>
                            <ComboBoxItem Content="Outro"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="1">
                        <TextBlock Text="Estado civil" Classes="FieldLabel"/>
                        <ComboBox x:Name="CmbEstadoCivil" Classes="FormCombo">
                            <ComboBoxItem Content="Solteiro(a)"/>
                            <ComboBoxItem Content="Casado(a)"/>
                            <ComboBoxItem Content="Divorciado(a)"/>
                            <ComboBoxItem Content="Viúvo(a)"/>
                        </ComboBox>
                    </StackPanel>
                 </Grid>     
                </StackPanel>
            </Border>

            <!-- ═══════════ CONTATO / ENDEREÇO ═══════════ -->
            <Border Background="{DynamicResource CardBg}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,16,16"
                    Width="380">
                <StackPanel Spacing="12">
                    <TextBlock Text="Contato e Endereço" Classes="SectionTitle"/>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" 
                          RowSpacing="10" ColumnSpacing="10">

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="CEP" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtCep" Classes="FormInput"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Número" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtNumero" Classes="FormInput"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                            <TextBlock Text="Logradouro" Classes=""/>
                            <TextBox x:Name="TxtLogradouro" Classes="FormInput"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Complemento" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtComplemento" Classes="FormInput"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1">
                            <TextBlock Text="Bairro" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtBairro" Classes="FormInput"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Grid.Column="0">
                            <TextBlock Text="Cidade" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtCidade" Classes="FormInput"/>
                        </StackPanel>

                       
                        <StackPanel Grid.Row="3" Grid.Column="1">
                            <TextBlock Text="Estado" Classes="FieldLabel"/>
                            <ComboBox x:Name="CmbEstado" Classes="FormCombo">
                                <ComboBoxItem Content="SP"/>
                                <ComboBoxItem Content="RJ"/>
                                <ComboBoxItem Content="MG"/>
                                <ComboBoxItem Content="RS"/>
                                <ComboBoxItem Content="PR"/>
                                <ComboBoxItem Content="SC"/>
                                <ComboBoxItem Content="BA"/>
                                <ComboBoxItem Content="GO"/>
                                <ComboBoxItem Content="DF"/>
                                <ComboBoxItem Content="PE"/>
                                <ComboBoxItem Content="CE"/>
                                <ComboBoxItem Content="AM"/>
                                <ComboBoxItem Content="PA"/>
                                <ComboBoxItem Content="MT"/>
                                <ComboBoxItem Content="MS"/>
                                <ComboBoxItem Content="ES"/>
                                <ComboBoxItem Content="RN"/>
                                <ComboBoxItem Content="PB"/>
                                <ComboBoxItem Content="AL"/>
                                <ComboBoxItem Content="PI"/>
                                <ComboBoxItem Content="SE"/>
                                <ComboBoxItem Content="MA"/>
                                <ComboBoxItem Content="TO"/>
                                <ComboBoxItem Content="RO"/>
                                <ComboBoxItem Content="AC"/>
                                <ComboBoxItem Content="AP"/>
                                <ComboBoxItem Content="RR"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="Telefone" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtTelefone" Classes="FormInput"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="1">
                            <TextBlock Text="E-mail" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtEmail" Classes="FormInput"/>
                        </StackPanel>

                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══════════ INFORMAÇÕES EXTRAS ═══════════ -->
            <Border Background="{DynamicResource CardBg}"
                    BorderBrush="{DynamicResource CardBorder}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,0,16,16"
                    Width="380">
                <StackPanel Spacing="12">
                    <TextBlock Text="Informações Adicionais" Classes="SectionTitle"/>

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" 
                          RowSpacing="10" ColumnSpacing="10">

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Profissão" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtProfissao" Classes="FormInput"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock Text="Preferência de horário" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtPreferenciaHorario" Classes="FormInput"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                            <TextBlock Text="Observações" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtObservacoes" Classes="FormInput FormTextArea"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Nome do pai" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtNomePai" Classes="FormInput"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="1">
                            <TextBlock Text="Nome da mãe" Classes="FieldLabel"/>
                            <TextBox x:Name="TxtNomeMae" Classes="FormInput"/>
                        </StackPanel>
                        
                        <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                  x:Name="ChkLembretes"
                                  Content="Quero receber lembretes"
                                  />
                       

                        

                    </Grid>
                </StackPanel>
            </Border>
            
        </WrapPanel>
    </ScrollViewer>
</Grid>
</UserControl>
