<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ConsultorioUI.Views.ProntuarioView"
             Background="{DynamicResource PageBg}">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════ HEADER ══════════ -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Foreground="{DynamicResource TextPrimary}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI">
                    <Run>Prontuário</Run>
                    <Run x:Name="Nome"/>
                </TextBlock>

                <TextBlock Text="Gerencie o cadastro e histórico dos seus pacientes"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ══════════ ODONTOGRAMA ══════════ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- COLUNA 0 — ODONTOGRAMA -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Números superiores -->
                    <RowDefinition Height="Auto"/> <!-- Checkboxes superiores -->
                    <RowDefinition Height="Auto"/> <!-- Linha do meio -->
                    <RowDefinition Height="Auto"/> <!-- Checkboxes inferiores -->
                    <RowDefinition Height="Auto"/> <!-- Números inferiores -->
                </Grid.RowDefinitions>

                <!-- Números — arcada superior -->
                <UniformGrid Grid.Row="0" Columns="16">
                    <TextBlock Text="18" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="17" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="16" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="15" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="14" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="13" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="12" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="11" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="21" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="22" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="23" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="24" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="25" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="26" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="27" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="28" HorizontalAlignment="Center" FontSize="11"/>
                </UniformGrid>

                <!-- Checkboxes — arcada superior -->
                <UniformGrid Grid.Row="1" Columns="16">
                    <CheckBox x:Name="Dente18" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente17" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente16" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente15" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente14" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente13" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente12" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente11" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente21" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente22" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente23" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente24" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente25" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente26" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente27" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente28" HorizontalAlignment="Center"/>
                </UniformGrid>

                <!-- Linha do meio -->
                <Border Grid.Row="2" Height="2" Background="#CFE3EC" Margin="0,10"/>

                <!-- Checkboxes — arcada inferior -->
                <UniformGrid Grid.Row="3" Columns="16">
                    <CheckBox x:Name="Dente48" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente47" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente46" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente45" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente44" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente43" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente42" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente41" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente31" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente32" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente33" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente34" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente35" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente36" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente37" HorizontalAlignment="Center"/>
                    <CheckBox x:Name="Dente38" HorizontalAlignment="Center"/>
                </UniformGrid>

                <!-- Números — arcada inferior -->
                <UniformGrid Grid.Row="4" Columns="16">
                    <TextBlock Text="48" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="47" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="46" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="45" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="44" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="43" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="42" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="41" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="31" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="32" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="33" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="34" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="35" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="36" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="37" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBlock Text="38" HorizontalAlignment="Center" FontSize="11"/>
                </UniformGrid>
            </Grid>

            <!-- COLUNA 1 — FACES DO DENTE -->
            <Grid Grid.Column="1" Margin="24,0,0,0">
                <StackPanel Spacing="6">
                    <TextBlock Text="Faces do Dente" FontWeight="SemiBold" FontSize="13"/>
                    <CheckBox x:Name="FaceVestibular"     Content="Vestibular"/>
                    <CheckBox x:Name="FaceLingual"        Content="Lingual/Palatina"/>
                    <CheckBox x:Name="FaceMesial"         Content="Mesial"/>
                    <CheckBox x:Name="FaceDistal"         Content="Distal"/>
                    <CheckBox x:Name="FaceOclusal"        Content="Oclusal/Incisal"/>
                    <Button 
                        Content="Salvar"
                    /> 
                </StackPanel>
                
            </Grid>

        </Grid>
    </Grid>
</UserControl>
