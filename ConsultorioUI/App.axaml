<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ConsultorioUI.App"
             xmlns:local="using:ConsultorioUI"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
     <Application.Resources>
         <ResourceDictionary>
             <ResourceDictionary.MergedDictionaries>
                 <ResourceInclude Source="avares://ConsultorioUI/Styles/Colors.axaml"/>
             </ResourceDictionary.MergedDictionaries>
         </ResourceDictionary>
     </Application.Resources>
             
     <Application.Styles>
         <FluentTheme/>
         <StyleInclude Source="avares://ConsultorioUI/Styles/AdicionarPacienteStyle.axaml"/>
         <StyleInclude Source="avares://ConsultorioUI/Styles/PacientesStyle.axaml"/>
         <StyleInclude Source="avares://ConsultorioUI/Styles/MostrarPerfilStyle.axaml"/>
     </Application.Styles>
</Application>