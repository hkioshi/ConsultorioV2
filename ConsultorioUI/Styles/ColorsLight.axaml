<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <SolidColorBrush x:Key="PageBg" Color="#F4F9FB"/>
    <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorder" Color="#C3D4DD"/>
    <SolidColorBrush x:Key="TableBg" Color="#D2DCE2"/>

    <!-- Interação -->
    <SolidColorBrush x:Key="RowHover" Color="#DCEFF8"/>
    <SolidColorBrush x:Key="RowSeparator" Color="#C9D9E2"/>

    <!-- Destaques -->
    <SolidColorBrush x:Key="AccentBlue" Color="#2E79C9"/>
    <SolidColorBrush x:Key="AccentMint" Color="#2AA99B"/>
    <SolidColorBrush x:Key="AccentSoft" Color="#7BBEEA"/>

    <!-- Texto -->
    <SolidColorBrush x:Key="TextPrimary" Color="#1A2633"/>
    <SolidColorBrush x:Key="TextMuted" Color="#526977"/>
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFF"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputBorder" Color="#AFC8D4"/>
    <SolidColorBrush x:Key="InputFocus" Color="#2E79C9"/>
    <SolidColorBrush x:Key="AccentPurple" Color="#8B42B4"/>

    <SolidColorBrush x:Key="InputPlaceholder" Color="#5D7382"/>

    <SolidColorBrush x:Key="ComboHoverBorder" Color="#2E79C9"/>
    <SolidColorBrush x:Key="ComboItemForeground" Color="#225C84"/>
    <SolidColorBrush x:Key="ComboItemSelected" Color="#DCEFF8"/>

</ResourceDictionary>