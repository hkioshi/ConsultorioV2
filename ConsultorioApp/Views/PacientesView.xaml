<UserControl x:Class="ConsultorioApp.Views.PacientesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F1E2A">

    <UserControl.Resources>

        <!-- ══ CORES ══ -->
        <SolidColorBrush x:Key="PageBg"          Color="#0F1E2A"/>
        <SolidColorBrush x:Key="CardBg"          Color="#1A3A52"/>
        <SolidColorBrush x:Key="CardBorder"      Color="#243F52"/>
        <SolidColorBrush x:Key="RowHover"        Color="#1A3A52"/>
        <SolidColorBrush x:Key="RowSeparator"    Color="#142030"/>
        <SolidColorBrush x:Key="AccentBlue"      Color="#3B87B8"/>
        <SolidColorBrush x:Key="AccentPurple"    Color="#A855C8"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#CCE4F0"/>
        <SolidColorBrush x:Key="TextMuted"       Color="#4A7A9B"/>
        <SolidColorBrush x:Key="TextCyan"        Color="#7ECFEE"/>
        <SolidColorBrush x:Key="InputBg"         Color="#0D2233"/>

        <!-- STATUS TAG: Ativo -->
        <Style x:Key="TagAtivo" TargetType="Border">
            <Setter Property="Background"       Value="#0D3320"/>
            <Setter Property="BorderBrush"      Value="#1A5C3A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="Padding"          Value="8,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="TagInativo" TargetType="Border">
            <Setter Property="Background"       Value="#2D1520"/>
            <Setter Property="BorderBrush"      Value="#5C2020"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="Padding"          Value="8,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="TagPendente" TargetType="Border">
            <Setter Property="Background"       Value="#2D2510"/>
            <Setter Property="BorderBrush"      Value="#5C4A20"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="Padding"          Value="8,2"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- BOTÃO PRIMÁRIO -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="#3B87B8"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E6E99"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#255880"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BOTÃO ÍCONE (editar/excluir) -->
        <Style x:Key="BtnIcon" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E4D6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SEARCH BOX -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"        Value="#0D2233"/>
            <Setter Property="Foreground"        Value="#CCE4F0"/>
            <Setter Property="CaretBrush"        Value="#7ECFEE"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="BorderBrush"       Value="#243F52"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="36,9,12,9"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- HEADER COLUNA DA TABELA -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#4A7A9B"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- CÉLULA PRIMÁRIA -->
        <Style x:Key="CellPrimary" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#CCE4F0"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- CÉLULA SECUNDÁRIA -->
        <Style x:Key="CellMuted" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#4A7A9B"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- CÉLULA DESTAQUE (próxima consulta) -->
        <Style x:Key="CellAccent" TargetType="TextBlock">
            <Setter Property="Foreground"        Value="#7ECFEE"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontFamily"        Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- LINHA DA TABELA hover -->
        <Style x:Key="TableRow" TargetType="Border">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#142030"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A3A52"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- FILTER CHIP -->
        <Style x:Key="FilterChip" TargetType="RadioButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderBrush"     Value="#243F52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#4A7A9B"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="GroupName"       Value="StatusFilter"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0D2233"/>
                                <Setter Property="Foreground" Value="#CCE4F0"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E4D6B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B87B8"/>
                                <Setter Property="Foreground" Value="#7ECFEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="16"/>
            <!-- Espaço -->
            <RowDefinition Height="Auto"/>
            <!-- Stats cards -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <!-- Search + Filtros -->
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <!-- Tabela -->
        </Grid.RowDefinitions>

        <!-- ══════════ HEADER ══════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Pacientes"
                           Foreground="#CCE4F0"
                           FontSize="20"
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI"/>
                <TextBlock Text="Gerencie o cadastro e histórico dos seus pacientes"
                           Foreground="#4A7A9B"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           Margin="0,3,0,0"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource BtnPrimary}"
                    VerticalAlignment="Center"
                    Click="BtnNovoPaciente_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="+"
                               FontSize="16"
                               FontWeight="Bold"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Novo Paciente"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>


        <!-- ══════════ SEARCH + FILTROS ══════════ -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search com ícone de lupa -->
            <Grid Grid.Column="0">

                <TextBox x:Name="TxtBusca"
                         Style="{StaticResource SearchBox}" 
                        
                        Text=""
                         TextChanged="TxtBusca_TextChanged">
                    <TextBox.Resources>
                        <Style TargetType="Border" BasedOn="{x:Null}"/>
                    </TextBox.Resources>
                </TextBox>
                <!-- Placeholder -->
                <TextBlock IsHitTestVisible="False"
                           Text="Buscar por nome, CPF ou telefone..."
                           Foreground="#2E5566"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           VerticalAlignment="Center"
                           Margin="75,0,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtBusca}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <!-- Ícone lupa -->
                <Path Data="M10 2C5.6 2 2 5.6 2 10C2 14.4 5.6 18 10 18C11.8 18 13.4 17.4 14.7 16.4L18.3 20L20 18.3L16.4 14.7C17.4 13.4 18 11.8 18 10C18 5.6 14.4 2 10 2ZM10 4C13.3 4 16 6.7 16 10C16 13.3 13.3 16 10 16C6.7 16 4 13.3 4 10C4 6.7 6.7 4 10 4Z"
                      Fill="#2E5566"
                      Width="16" Height="16"
                      Stretch="Uniform"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Margin="30,0,0,0"
                      IsHitTestVisible="False"/>
            </Grid>

            <!-- Filter chips -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton Content="ID"   Style="{StaticResource FilterChip}" IsChecked="True" Margin="0,0,6,0" Checked="RadioButton_Checked"/>
                <RadioButton Content="Nome"  Style="{StaticResource FilterChip}" Margin="0,0,6,0"/>
                <RadioButton Content="CPF" Style="{StaticResource FilterChip}" Margin="0,0,6,0"/>
            </StackPanel>
        </Grid>

        <!-- ══════════ TABELA ══════════ -->
        <Border Grid.Row="6"
                Background="#1A3A52"
                CornerRadius="12"
                BorderBrush="#243F52"
                BorderThickness="1"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Cabeçalho -->
                    <RowDefinition Height="*"/>
                    <!-- Linhas -->
                </Grid.RowDefinitions>

                <!-- Cabeçalho da tabela -->
                <Border Grid.Row="0"
                        Background="#142C3F"
                        BorderBrush="#243F52"
                        BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <!-- ID -->
                            <ColumnDefinition Width="3*"/>
                            <!-- Paciente -->
                            <ColumnDefinition Width="2*"/>
                            <!-- Telefone -->
                            <ColumnDefinition Width="2*"/>
                            <!-- CPF -->
                            <ColumnDefinition Width="2*"/>
                            <!-- Status -->
                            <ColumnDefinition Width="100"/>
                            <!-- Ações -->
                        </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="ID" 
                           Style="{StaticResource ColHeader}" />

                        <TextBlock Grid.Column="1" Text="PACIENTE" 
                           Style="{StaticResource ColHeader}" />

                        <TextBlock Grid.Column="2" Text="TELEFONE" 
                           Style="{StaticResource ColHeader}" />

                         <TextBlock Grid.Column="3" Text="CPF" 
                           Style="{StaticResource ColHeader}" />

                        <TextBlock Grid.Column="4" Text="STATUS" 
                           Style="{StaticResource ColHeader}" />

                        <TextBlock Grid.Column="5" Text="AÇÕES" 
                           Style="{StaticResource ColHeader}" />    
                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</UserControl>
