<Window x:Class="ConsultorioApp.Views.NovoPacienteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Novo Paciente"
        Width="780" Height="700"
        MinWidth="680" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        Background="#0F1E2A"
        FontFamily="Segoe UI"
        ResizeMode="CanResize">

    <Window.Resources>

        <!-- ══ CORES ══ -->
        <SolidColorBrush x:Key="PageBg"       Color="#0F1E2A"/>
        <SolidColorBrush x:Key="CardBg"       Color="#1A3A52"/>
        <SolidColorBrush x:Key="CardBorder"   Color="#243F52"/>
        <SolidColorBrush x:Key="InputBg"      Color="#0D2233"/>
        <SolidColorBrush x:Key="InputBorder"  Color="#243F52"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#3B87B8"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#CCE4F0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#4A7A9B"/>
        <SolidColorBrush x:Key="TextCyan"     Color="#7ECFEE"/>
        <SolidColorBrush x:Key="Divider"      Color="#1E3D52"/>

        <!-- LABEL -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#7ECFEE"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,5"/>
        </Style>

        <!-- SEÇÃO TÍTULO -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#4A7A9B"/>
            <Setter Property="FontSize"    Value="9.5"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,12"/>
        </Style>

        <!-- TEXTBOX BASE -->
        <Style x:Key="FormInput" TargetType="TextBox">
            <Setter Property="Background"             Value="#0D2233"/>
            <Setter Property="Foreground"             Value="#CCE4F0"/>
            <Setter Property="CaretBrush"             Value="#7ECFEE"/>
            <Setter Property="FontFamily"             Value="Segoe UI"/>
            <Setter Property="FontSize"               Value="13"/>
            <Setter Property="BorderBrush"            Value="#243F52"/>
            <Setter Property="BorderThickness"        Value="1"/>
            <Setter Property="Height"                 Value="36"/>
            <Setter Property="Padding"                Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B87B8"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B87B8"/>
                                <Setter TargetName="Bd" Property="Background"  Value="#112840"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXTAREA -->
        <Style x:Key="FormTextArea" TargetType="TextBox" BasedOn="{StaticResource FormInput}">
            <Setter Property="Height"               Value="72"/>
            <Setter Property="TextWrapping"         Value="Wrap"/>
            <Setter Property="AcceptsReturn"        Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment"    Value="Top"/>
            <Setter Property="Padding"              Value="10,8"/>
        </Style>

        <!-- COMBOBOX -->
        <Style x:Key="FormCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#0D2233"/>
            <Setter Property="Foreground"      Value="#CCE4F0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderBrush"     Value="#243F52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <ToggleButton x:Name="ToggleBtn"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Cursor="Hand"/>
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="10,0,30,0"
                                                  VerticalAlignment="Center"/>
                                <Path x:Name="Arrow"
                                      Data="M0 0L4 4L8 0"
                                      Fill="#4A7A9B"
                                      Width="8" Height="5"
                                      Stretch="Uniform"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"
                                      Margin="0,0,10,0"
                                      IsHitTestVisible="False"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Fade"
                                       Placement="Bottom">
                                    <Border Background="#1A3A52"
                                            BorderBrush="#3B87B8"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="200">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B87B8"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B87B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"  Value="#CCE4F0"/>
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="Padding"     Value="12,8"/>
                        <Setter Property="FontFamily"  Value="Segoe UI"/>
                        <Setter Property="FontSize"    Value="13"/>
                        <Setter Property="Cursor"      Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#1E4D6B"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DATEPICKER -->
        <Style x:Key="FormDate" TargetType="DatePicker">
            <Setter Property="Background"      Value="#0D2233"/>
            <Setter Property="Foreground"      Value="#CCE4F0"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderBrush"     Value="#243F52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="10,0"/>
        </Style>

        <!-- CHECKBOX TOGGLE -->
        <Style x:Key="ToggleCheck" TargetType="CheckBox">
            <Setter Property="Foreground"   Value="#CCE4F0"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="38" Height="22"
                                    CornerRadius="11"
                                    Background="#1E3D52"
                                    BorderBrush="#243F52"
                                    BorderThickness="1"
                                    Margin="0,0,10,0">
                                <Ellipse x:Name="Knob"
                                         Width="16" Height="16"
                                         Fill="#4A7A9B"
                                         HorizontalAlignment="Left"
                                         Margin="2,0,0,0"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box"  Property="Background"   Value="#3B87B8"/>
                                <Setter TargetName="Box"  Property="BorderBrush"  Value="#3B87B8"/>
                                <Setter TargetName="Knob" Property="Fill"         Value="White"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Knob" Property="Margin"       Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BOTÃO PRIMÁRIO -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#3B87B8"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="24,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2E6E99"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#255880"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BOTÃO SECUNDÁRIO -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#4A7A9B"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="24,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderBrush"     Value="#243F52"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3A52"/>
                                <Setter Property="Foreground" Value="#CCE4F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ABA DE SEÇÃO -->
        <Style x:Key="TabBtn" TargetType="RadioButton">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#4A7A9B"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="16,10"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="GroupName"       Value="FormTabs"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <Border x:Name="Underline"
                                        Height="2"
                                        CornerRadius="1"
                                        Background="#3B87B8"
                                        VerticalAlignment="Bottom"
                                        Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground"                   Value="#7ECFEE"/>
                                <Setter TargetName="Underline" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CCE4F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Título / header -->
            <RowDefinition Height="Auto"/>  <!-- Tabs de seção -->
            <RowDefinition Height="*"/>     <!-- Conteúdo -->
            <RowDefinition Height="Auto"/>  <!-- Footer / botões -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0"
                Background="#1A3A52"
                BorderBrush="#243F52"
                BorderThickness="0,0,0,1"
                Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Cadastro de Paciente"
                               Foreground="#CCE4F0"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Preencha os dados abaixo para adicionar um novo paciente"
                               Foreground="#4A7A9B"
                               FontSize="11"
                               Margin="0,3,0,0"/>
                </StackPanel>
                <!-- Botão fechar X -->
                <Button Grid.Column="1"
                        Content="✕"
                        Foreground="#4A7A9B"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="16"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="BtnFechar_Click"/>
            </Grid>
        </Border>

        <!-- ══ TABS ══ -->
        <Border Grid.Row="1"
                Background="#142C3F"
                BorderBrush="#243F52"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,0">
                <RadioButton Content="Dados Pessoais" Style="{StaticResource TabBtn}" IsChecked="True"
                             Checked="Tab_Checked" Tag="TabPessoal"/>
                <RadioButton Content="Endereço e Contato" Style="{StaticResource TabBtn}"
                             Checked="Tab_Checked" Tag="TabContato"/>
                <RadioButton Content="Informações Extras" Style="{StaticResource TabBtn}"
                             Checked="Tab_Checked" Tag="TabExtra"/>
            </StackPanel>
        </Border>

        <!-- ══ CONTEÚDO DAS TABS ══ -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="28,24,28,8">
            <StackPanel>

                <!-- ════ TAB 1: DADOS PESSOAIS ════ -->
                <StackPanel x:Name="TabPessoal" Visibility="Visible">

                    <TextBlock Style="{StaticResource SectionTitle}" Text="IDENTIFICAÇÃO"/>

                    <!-- Nome -->
                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Nome completo *"/>
                        <TextBox x:Name="TxtNome" Style="{StaticResource FormInput}"/>
                    </StackPanel>

                    <!-- CPF / RG -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="CPF *"/>
                            <TextBox x:Name="TxtCpf" Style="{StaticResource FormInput}"
                                     MaxLength="14" TextChanged="TxtCpf_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="RG"/>
                            <TextBox x:Name="TxtRg" Style="{StaticResource FormInput}" MaxLength="15"/>
                        </StackPanel>
                    </Grid>

                    <!-- Data Nasc / Gênero / Estado Civil -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Data de nascimento *"/>
                            <DatePicker x:Name="DtNascimento"
                                        Style="{StaticResource FormDate}"
                                        Language="pt-BR"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Gênero"/>
                            <ComboBox x:Name="CmbGenero" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="Feminino"/>
                                <ComboBoxItem Content="Masculino"/>
                                <ComboBoxItem Content="Não binário"/>
                                <ComboBoxItem Content="Prefiro não informar"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Estado civil"/>
                            <ComboBox x:Name="CmbEstadoCivil" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="Solteiro(a)"/>
                                <ComboBoxItem Content="Casado(a)"/>
                                <ComboBoxItem Content="Divorciado(a)"/>
                                <ComboBoxItem Content="Viúvo(a)"/>
                                <ComboBoxItem Content="União estável"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Responsável / Recomendado por -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Pessoa responsável"/>
                            <ComboBox x:Name="CmbResponsavel" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="— Selecione —"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Recomendado por"/>
                            <ComboBox x:Name="CmbRecomendadoPor" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="— Selecione —"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                </StackPanel>

                <!-- ════ TAB 2: ENDEREÇO E CONTATO ════ -->
                <StackPanel x:Name="TabContato" Visibility="Collapsed">

                    <TextBlock Style="{StaticResource SectionTitle}" Text="ENDEREÇO"/>

                    <!-- CEP -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="CEP"/>
                            <Grid>
                                <TextBox x:Name="TxtCep" Style="{StaticResource FormInput}"
                                         MaxLength="9" TextChanged="TxtCep_TextChanged"/>
                                <Button x:Name="BtnBuscarCep"
                                        Content="Buscar"
                                        Foreground="#7ECFEE"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        FontFamily="Segoe UI"
                                        Cursor="Hand"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0"
                                        Click="BtnBuscarCep_Click"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Logradouro"/>
                            <TextBox x:Name="TxtLogradouro" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Número / Complemento -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Número"/>
                            <TextBox x:Name="TxtNumero" Style="{StaticResource FormInput}" MaxLength="10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Complemento"/>
                            <TextBox x:Name="TxtComplemento" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Bairro / Cidade / Estado -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Bairro"/>
                            <TextBox x:Name="TxtBairro" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Cidade"/>
                            <TextBox x:Name="TxtCidade" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="UF"/>
                            <ComboBox x:Name="CmbEstado" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="SP"/>
                                <ComboBoxItem Content="RJ"/>
                                <ComboBoxItem Content="MG"/>
                                <ComboBoxItem Content="RS"/>
                                <ComboBoxItem Content="PR"/>
                                <ComboBoxItem Content="SC"/>
                                <ComboBoxItem Content="BA"/>
                                <ComboBoxItem Content="GO"/>
                                <ComboBoxItem Content="DF"/>
                                <ComboBoxItem Content="PE"/>
                                <ComboBoxItem Content="CE"/>
                                <ComboBoxItem Content="AM"/>
                                <ComboBoxItem Content="PA"/>
                                <ComboBoxItem Content="MT"/>
                                <ComboBoxItem Content="MS"/>
                                <ComboBoxItem Content="ES"/>
                                <ComboBoxItem Content="RN"/>
                                <ComboBoxItem Content="PB"/>
                                <ComboBoxItem Content="AL"/>
                                <ComboBoxItem Content="PI"/>
                                <ComboBoxItem Content="SE"/>
                                <ComboBoxItem Content="MA"/>
                                <ComboBoxItem Content="TO"/>
                                <ComboBoxItem Content="RO"/>
                                <ComboBoxItem Content="AC"/>
                                <ComboBoxItem Content="AP"/>
                                <ComboBoxItem Content="RR"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Divisor -->
                    <Border Background="#1E3D52" Height="1" Margin="0,0,0,20"/>

                    <TextBlock Style="{StaticResource SectionTitle}" Text="CONTATO"/>

                    <!-- Telefone / Email -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Telefone / WhatsApp *"/>
                            <TextBox x:Name="TxtTelefone" Style="{StaticResource FormInput}"
                                     MaxLength="15" TextChanged="TxtTelefone_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="E-mail"/>
                            <TextBox x:Name="TxtEmail" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>

                <!-- ════ TAB 3: INFORMAÇÕES EXTRAS ════ -->
                <StackPanel x:Name="TabExtra" Visibility="Collapsed">

                    <TextBlock Style="{StaticResource SectionTitle}" Text="FAMÍLIA"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Nome do pai"/>
                            <TextBox x:Name="TxtNomePai" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Nome da mãe"/>
                            <TextBox x:Name="TxtNomeMae" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Nome do cônjuge"/>
                            <TextBox x:Name="TxtNomeConjuge" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Profissão"/>
                            <TextBox x:Name="TxtProfissao" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#1E3D52" Height="1" Margin="0,0,0,20"/>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="CONVÊNIO"/>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Convênio"/>
                            <TextBox x:Name="TxtConvenio" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Número do convênio"/>
                            <TextBox x:Name="TxtNumeroConvenio" Style="{StaticResource FormInput}"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#1E3D52" Height="1" Margin="0,0,0,20"/>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="PREFERÊNCIAS"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Como nos conheceu"/>
                            <ComboBox x:Name="CmbConheceuPor" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="Indicação de paciente"/>
                                <ComboBoxItem Content="Redes sociais"/>
                                <ComboBoxItem Content="Google"/>
                                <ComboBoxItem Content="Plano de saúde"/>
                                <ComboBoxItem Content="Outro"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Preferência de horário"/>
                            <ComboBox x:Name="CmbPreferenciaHorario" Style="{StaticResource FormCombo}">
                                <ComboBoxItem Content="Manhã"/>
                                <ComboBoxItem Content="Tarde"/>
                                <ComboBoxItem Content="Qualquer horário"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,14">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="Observações"/>
                        <TextBox x:Name="TxtObservacoes" Style="{StaticResource FormTextArea}"/>
                    </StackPanel>

                    <CheckBox x:Name="ChkReceberLembretes"
                              Style="{StaticResource ToggleCheck}"
                              Content="Quero receber lembretes de consultas"
                              IsChecked="True"
                              Margin="0,4,0,0"/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ FOOTER ══ -->
        <Border Grid.Row="3"
                Background="#142C3F"
                BorderBrush="#243F52"
                BorderThickness="0,1,0,0"
                Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Indicador de campos obrigatórios -->
                <TextBlock Grid.Column="0"
                           Text="* Campos obrigatórios"
                           Foreground="#3A6070"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Cancelar"
                            Style="{StaticResource BtnSecondary}"
                            Margin="0,0,10,0"
                            Click="BtnFechar_Click"/>
                    <Button Content="Salvar Paciente"
                            Style="{StaticResource BtnPrimary}"
                            Click="BtnSalvar_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
