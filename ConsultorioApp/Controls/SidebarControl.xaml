<UserControl x:Class="ConsultorioApp.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="230">

    <UserControl.Resources>
        <!-- Cores -->
        <SolidColorBrush x:Key="SidebarBg"       Color="#1A3A52"/>
        <SolidColorBrush x:Key="AccentBlue"       Color="#3B87B8"/>
        <SolidColorBrush x:Key="AccentPurple"     Color="#A855C8"/>
        <SolidColorBrush x:Key="TextMuted"        Color="#7ECFEE"/>
        <SolidColorBrush x:Key="NavItemHover"     Color="#0D2233"/>
        <SolidColorBrush x:Key="NavItemActive"    Color="#1E4D6B"/>
        <SolidColorBrush x:Key="SectionLabel"     Color="#4A7A9B"/>
        <SolidColorBrush x:Key="Divider"          Color="#243F52"/>

        <!-- Estilo base do item de navegação -->
        <Style x:Key="NavItemStyle" TargetType="RadioButton">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#7A9BAD"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="Height"           Value="40"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="GroupName"        Value="Navigation"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="0,1">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="12,0">
                                <ContentPresenter x:Name="Icon"
                                                  Content="{TemplateBinding Tag}"
                                                  Width="16" Height="16"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0"
                                                  Opacity="0.5"/>
                                <TextBlock Text="{TemplateBinding Content}"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd"    Property="Background" Value="#0D2233"/>
                                <Setter Property="Foreground" Value="#CCDDEA"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd"    Property="Background" Value="#1E4D6B"/>
                                <Setter Property="Foreground" Value="#7ECFEE"/>
                                <Setter TargetName="Icon"  Property="Opacity"    Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label de seção -->
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#3D6070"/>
            <Setter Property="FontSize"     Value="9.5"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="Margin"       Value="12,12,0,4"/>
            
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource SidebarBg}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Brand -->
                <RowDefinition Height="*"/>     <!-- Nav -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ══════════════ BRAND ══════════════ -->
            <Border Grid.Row="0"
                    BorderBrush="{StaticResource Divider}"
                    BorderThickness="0,0,0,1"
                    Padding="20,24,20,18">
                <StackPanel>
                    <TextBlock FontSize="12"
                               FontWeight="Bold"
                               FontFamily="Segoe UI"
                               Foreground="White"
                               LineHeight="18"
                               TextWrapping="Wrap">
                        Dra. Celia Akemi<LineBreak/>Watanabe Yamauchi
                    </TextBlock>
                    <Border Background="#1E3D52"
                            CornerRadius="4"
                            Padding="7,2"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Left">
                        <TextBlock Text="CRO-SP 000000"
                                   Foreground="#5BB8E0"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"
                                  />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ══════════════ NAVEGAÇÃO ══════════════ -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="10,14,10,0">

                    <TextBlock Text="PRINCIPAL" Style="{StaticResource SectionLabelStyle}"/>

                    <!-- Início -->
                    <RadioButton x:Name="NavInicio"
                                 Content="Início"
                                 Style="{StaticResource NavItemStyle}"
                                 IsChecked="True"
                                 Click="NavInicio_Click">
                        <RadioButton.Tag>
                            <Path Data="M2 10.5L10 3L18 10.5V19C18 19.6 17.6 20 17 20H13V16H7V20H3C2.4 20 2 19.6 2 19V10.5Z"
                                  Fill="#7ECFEE" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>

                    <!-- Pacientes -->
                    <RadioButton x:Name="NavPacientes"
                                 Content="Pacientes"
                                 Style="{StaticResource NavItemStyle}"
                                 Click="NavPacientes_Click">
                        <RadioButton.Tag>
                            <Path Data="M9 6C9 7.7 7.7 9 6 9S3 7.7 3 6 4.3 3 6 3 9 4.3 9 6ZM17 6C17 7.7 15.7 9 14 9S11 7.7 11 6 12.3 3 14 3 17 4.3 17 6ZM12.9 17C12.95 16.7 13 16.3 13 16C13 13.7 11.5 11.7 9.5 11.1 8.4 10.7 7.2 10.5 6 10.5 3.2 10.5 1 12.5 1 15V17H12.9ZM19 15V17H13.1C13.1 16.7 13.1 16.3 13.1 16 13.1 14.2 12.3 12.6 11 11.5 11.6 11.2 12.3 11 13 11 16.3 11 19 12.7 19 15Z"
                                  Fill="#7ECFEE" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>

                    <!-- Agenda -->
                    <RadioButton x:Name="NavAgenda"
                                 Content="Agenda"
                                 Style="{StaticResource NavItemStyle}"
                                 Click="NavAgenda_Click">
                        <RadioButton.Tag>
                            <Path Data="M6 2C5.4 2 5 2.4 5 3V4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H16C17.1 20 18 19.1 18 18V6C18 4.9 17.1 4 16 4H15V3C15 2.4 14.6 2 14 2S13 2.4 13 3V4H7V3C7 2.4 6.6 2 6 2ZM6 9C5.4 9 5 8.6 5 8S5.4 7 6 7H14C14.6 7 15 7.4 15 8S14.6 9 14 9H6Z"
                                  Fill="#7ECFEE" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>

                    <!-- Financeiro -->
                    <RadioButton x:Name="NavFinanceiro"
                                 Content="Financeiro"
                                 Style="{StaticResource NavItemStyle}"
                                 Click="NavFinanceiro_Click">
                        <RadioButton.Tag>
                            <Path Data="M4 4C2.9 4 2 4.9 2 6V7H18V6C18 4.9 17.1 4 16 4H4ZM2 9V15C2 16.1 2.9 17 4 17H16C17.1 17 18 16.1 18 15V9H2ZM5 13C5 12.4 5.4 12 6 12H7C7.6 12 8 12.4 8 13S7.6 14 7 14H6C5.4 14 5 13.6 5 13ZM10 12C9.4 12 9 12.4 9 13S9.4 14 10 14H11C11.6 14 12 13.6 12 13S11.6 12 11 12H10Z"
                                  Fill="#7ECFEE" Stretch="Uniform"/>
                        </RadioButton.Tag>
                    </RadioButton>

                    <TextBlock Text="SISTEMA" Style="{StaticResource SectionLabelStyle}" Margin="12,16,0,4"/>

                    <!-- Configurações -->
                    <RadioButton x:Name="NavConfiguracoes"
                        Content="Configurações"
                        Style="{StaticResource NavItemStyle}"
                        Click="NavConfiguracoes_Click" Checked="NavConfiguracoes_Checked_1">
                        <RadioButton.Tag>
                            <Viewbox Width="16" Height="16" Stretch="Uniform">
                                <Path
                                Fill="#7ECFEE"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Data="M19.14,12.94A7.49,7.49 0 0,0 19.2,12A7.49,7.49 0 0,0 19.14,11.06L21.19,9.47C21.37,9.34 21.42,9.08 21.31,8.88L19.31,5.12C19.2,4.92 18.95,4.84 18.74,4.92L16.34,5.89C15.84,5.5 15.3,5.17 14.71,4.93L14.34,2.39C14.31,2.18 14.13,2 13.91,2H10.09C9.87,2 9.69,2.18 9.66,2.39L9.29,4.93C8.7,5.17 8.16,5.5 7.66,5.89L5.26,4.92C5.05,4.84 4.8,4.92 4.69,5.12L2.69,8.88C2.58,9.08 2.63,9.34 2.81,9.47L4.86,11.06C4.8,11.37 4.75,11.68 4.75,12C4.75,12.32 4.8,12.63 4.86,12.94L2.81,14.53C2.63,14.66 2.58,14.92 2.69,15.12L4.69,18.88C4.8,19.08 5.05,19.16 5.26,19.08L7.66,18.11C8.16,18.5 8.7,18.83 9.29,19.07L9.66,21.61C9.69,21.82 9.87,22 10.09,22H13.91C14.13,22 14.31,21.82 14.34,21.61L14.71,19.07C15.3,18.83 15.84,18.5 16.34,18.11L18.74,19.08C18.95,19.16 19.2,19.08 19.31,18.88L21.31,15.12C21.42,14.92 21.37,14.66 21.19,14.53L19.14,12.94M12,15.5A3.5,3.5 0 1,1 15.5,12A3.5,3.5 0 0,1 12,15.5Z"/>
                            </Viewbox>
                        </RadioButton.Tag>
                    </RadioButton>

                </StackPanel>
            </ScrollViewer>

            <!-- ══════════════ FOOTER / USUÁRIO ══════════════ -->
            <Border Grid.Row="2"
                    BorderBrush="{StaticResource Divider}"
                    BorderThickness="0,1,0,0"
                    Padding="10,14">
                <Border CornerRadius="8" Padding="12,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Avatar gradiente -->
                        <Border Width="30" Height="30" CornerRadius="15" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B87B8" Offset="0"/>
                                    <GradientStop Color="#A855C8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="CY"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Dra. Celia"
                                       Foreground="#AABFCC"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="Administradora"
                                       Foreground="#3D6070"
                                       FontSize="10"
                                       FontFamily="Segoe UI"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

        </Grid>
    </Border>
</UserControl>
